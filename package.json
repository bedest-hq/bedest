{
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "^1.4.8",
    "@elysiajs/jwt": "^1.4.1",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.27",
    "elysia-rate-limit": "^4.5.1",
    "pg": "^8.19.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.0",
    "@elysiajs/swagger": "^1.3.1",
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.9",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "scripts": {
    "dev": "NODE_ENV=development bun --watch src/index.ts",
    "build": "bun build src/index.ts --target bun --outdir ./dist",
    "start": "NODE_ENV=production bun dist/index.js",
    "test": "bun test",
    "mock": "bun run src/scripts/mock/MockData.ts",
    "check:ts": "tsc --noEmit",
    "check:lint": "eslint 'src/**/*.{ts,js}' --max-warnings=0",
    "check:files": "bun run check:ts && bun run check:lint",
    "db:re": "bun run src/scripts/database/DatabaseReset.ts",
    "db:gen": "bun run drizzle-kit generate",
    "db:mig": "bun run drizzle-kit migrate",
    "db:sync": "bun run db:gen && bun run db:mig",
    "db:up": "rm -rf drizzle && bun run db:re && bun run db:sync",
    "app:dev": "bun run db:up && bun run mock"
  }
}
